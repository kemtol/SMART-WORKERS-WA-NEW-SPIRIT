# Kredensial akun AMS read-only. Jangan commit file config/afml.env.
AMS_USERNAME=
AMS_PASSWORD=
AMS_BASE_URL=https://ams.smartaviation.co.id

# Poll setiap 30 menit dan rekonsiliasi 14 hari terakhir.
AFML_REFRESH_SECONDS=1800
AFML_LOOKBACK_DAYS=14
AFML_HTTP_TIMEOUT_SECONDS=30
AFML_HISTORICAL_REFRESH_HOURS=24
AFML_SHEETS_BATCH_SIZE=25

# Nama tab Google Sheets.
GOOGLE_SHEETS_AFML_RAW_TAB=AFML_RAW
GOOGLE_SHEETS_AFML_LEGS_TAB=AFML_LEGS
GOOGLE_SHEETS_AFML_RECON_TAB=AFML_RECON
